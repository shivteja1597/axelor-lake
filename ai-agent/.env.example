# Groq
GROQ_API_KEY=replace_with_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Axelor application database
# Match these with src/main/resources/axelor-config.properties.
AXELOR_DB_HOST=localhost
AXELOR_DB_PORT=5432
AXELOR_DB_NAME=axelor4
AXELOR_DB_USER=postgres
AXELOR_DB_PASSWORD=root

# Safety controls
MAX_DB_ROWS=50

