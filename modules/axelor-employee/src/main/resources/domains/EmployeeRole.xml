<?xml version="1.0" encoding="UTF-8"?>
<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/domain-models
  https://axelor.com/xml/ns/domain-models/domain-models_8.1.xsd">

  <module name="employee" package="com.axelor.employee.db"/>

  <entity name="EmployeeRole">

    <string name="role" required="true" namecolumn="true"/>

    <one-to-many name="employees" ref="Employee" mappedBy="role"/>

  </entity>

</domain-models>
