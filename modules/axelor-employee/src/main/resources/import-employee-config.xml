<?xml version="1.0" encoding="UTF-8"?>
<csv-inputs xmlns="http://axelor.com/xml/ns/data-import"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/data-import http://axelor.com/xml/ns/data-import/data-import_8.0.xsd">

  <input file="employee_department.csv" separator=";"
    type="com.axelor.employee.db.EmployeeDepartment" search="self.code = :code"/>

  <input file="employee_role.csv" separator=";" type="com.axelor.employee.db.EmployeeRole"
    search="self.role = :role"/>

  <input file="employee_employee.csv" separator=";" type="com.axelor.employee.db.Employee"
    search="self.firstName = :firstName AND self.lastName = :lastName AND self.department.code = :departmentCode">
    <bind to="department" column="departmentCode" search="self.code = :departmentCode"/>
    <bind to="role" column="roleName" search="self.role = :roleName"/>
  </input>

</csv-inputs>
