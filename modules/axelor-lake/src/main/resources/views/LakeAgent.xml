<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views
  https://axelor.com/xml/ns/object-views/object-views_8.1.xsd">

  <form name="lake-ai-agent-form" title="Lakehouse AI Agent" model="com.axelor.utils.db.Wizard"
    width="large" canSave="false" canNew="false" canCopy="false">
    <panel name="lakeAiAgentPromptPanel" title="Ask About This Project" colSpan="12">
      <field name="$agentQuestion" title="Question" type="string" colSpan="12"/>
      <button name="askLakeAgentBtn" title="Ask Agent"
        onClick="action-method-lake-ai-agent-ask"/>
    </panel>
    <panel name="lakeAiAgentAnswerPanel" title="Answer" colSpan="12">
      <field name="$agentAnswer" title="Response" type="string" widget="Text" readonly="true"
        colSpan="12"/>
    </panel>
  </form>

  <action-method name="action-method-lake-ai-agent-ask">
    <call class="com.axelor.lake.web.LakehouseController" method="askLakeAgent"/>
  </action-method>

  <action-view name="lake.ai.agent.view" title="Lakehouse AI Agent"
    model="com.axelor.utils.db.Wizard">
    <view type="form" name="lake-ai-agent-form"/>
  </action-view>

</object-views>
