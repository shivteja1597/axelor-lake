<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/object-views
  https://axelor.com/xml/ns/object-views/object-views_8.1.xsd">

  <grid name="lake-department-grid" title="Departments"
    model="com.axelor.lake.db.LakeDepartment" orderBy="name">
    <field name="name"/>
  </grid>

  <form name="lake-department-form" title="Department"
    model="com.axelor.lake.db.LakeDepartment">
    <panel>
      <field name="name"/>
    </panel>
  </form>

  <grid name="lake-role-grid" title="Roles" model="com.axelor.lake.db.LakeRole" orderBy="name">
    <field name="name"/>
  </grid>

  <form name="lake-role-form" title="Role" model="com.axelor.lake.db.LakeRole">
    <panel>
      <field name="name"/>
    </panel>
  </form>

  <grid name="lake-status-grid" title="Statuses" model="com.axelor.lake.db.LakeStatus"
    orderBy="name">
    <field name="name"/>
  </grid>

  <form name="lake-status-form" title="Status" model="com.axelor.lake.db.LakeStatus">
    <panel>
      <field name="name"/>
    </panel>
  </form>

</object-views>
