<?xml version="1.0" encoding="UTF-8"?>
<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/domain-models
  https://axelor.com/xml/ns/domain-models/domain-models_8.1.xsd">

  <module name="lake" package="com.axelor.lake.db"/>

  <entity name="LakeEmployee">
    <string name="employeeId" required="true"/>
    <string name="name" required="true" namecolumn="true"/>
    <string name="department" required="true"/>
    <integer name="age" required="true" min="18" max="100"/>
    <decimal name="salary" required="true" min="0" precision="20" scale="2"/>
    <string name="status" required="true"/>
    <string name="role"/>
  </entity>


  <entity name="LakeDepartment">
    <string name="name" required="true" unique="true" namecolumn="true"/>
  </entity>

  <entity name="LakeRole">
    <string name="name" required="true" unique="true" namecolumn="true"/>
  </entity>

  <entity name="LakeStatus">
    <string name="name" required="true" unique="true" namecolumn="true"/>
  </entity>

</domain-models>
