<?xml version="1.0" encoding="UTF-8"?>
<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://axelor.com/xml/ns/domain-models
  https://axelor.com/xml/ns/domain-models/domain-models_8.1.xsd">

  <module name="lake" package="com.axelor.lake.db"/>

  <entity name="LakehouseTable">
    <string name="tableName" required="true" unique="true" namecolumn="true"/>
    <string name="metadataPath" required="true" large="true"/>
    <datetime name="uploadedAt" required="true"/>
    <long name="uploadedRowCount"/>
    <long name="rowCount"/>
    <string name="syncStatus"/>
    <datetime name="lastSyncAt"/>
    <string name="syncMessage" large="true" multiline="true"/>
    <string name="queryPreview" large="true" multiline="true" transient="true"/>
  </entity>

</domain-models>

